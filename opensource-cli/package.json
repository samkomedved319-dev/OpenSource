{
  "name": "opensource",
  "version": "1.1.0",
  "description": "OpenSource CLI — Local-First AI Coding Agent. No API keys required. Runs on Ollama. Deep Obsidian Vault integration. Streaming output. Strong AI identity. Self-improving skills.",
  "main": "dist/index.js",
  "bin": {
    "opensource": "dist/index.js",
    "os-cli": "dist/index.js"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "npm install && npm run build",
    "run": "npm install && npm run build && node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "ai",
    "coding",
    "agent",
    "cli",
    "llm",
    "autonomous",
    "multi-agent",
    "mcp",
    "terminal",
    "local-first",
    "obsidian",
    "ollama",
    "open-source"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.12.0",
    "chalk": "^5.3.0",
    "cli-spinners": "^3.0.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "figlet": "^1.7.0",
    "gpt-tokenizer": "^2.0.0",
    "ignore": "^6.0.0",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0",
    "openai": "^4.80.0",
    "ora": "^8.0.0",
    "p-queue": "^8.0.0",
    "simple-git": "^3.25.0",
    "tinyglobby": "^0.2.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
